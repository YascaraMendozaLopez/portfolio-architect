---
import { ContactForm } from './ContactForm';

import { TelephoneIcon } from '../assets/icons/TelephoneIcon';
import { WhatsappIcon } from '../assets/icons/Whatsapp';
import { EmailIcon } from '../assets/icons/EmailIcon';
import CornerLeft from '../../public/images/CornerLeft.svg';
---

<section class={`relative min-h-screen w-full bg-[#F5F0E8] overflow-hidden flex items-center justify-center p-8 lg:p-20`}>
  
  <div class="absolute inset-0 pointer-events-none opacity-20" 
       style="background-image: linear-gradient(#8B7355 1px, transparent 1px), linear-gradient(90deg, #8B7355 1px, transparent 1px); background-size: calc(100% / 7) calc(100% / 5);">
  </div>

  <img src={CornerLeft.src} class="absolute bottom-10 md:w-[346px] md:h-[220px] left-13" />

  <div class="relative z-10 grid lg:grid-cols-2 gap-8 items-start w-full max-w-7xl">
    
    <div class="flex flex-col gap-16 ml-3">
      <div class="space-y-4 -ml-20">
        <span class="text-[#8B7355] font-bold tracking-[0.2em] text-sm uppercase">Contacto</span>
        <h2 class="text-[48px] font-light leading-tight">
          Comencemos tu <span class="font-bold italic text-[#8B7355]">proyecto</span>
        </h2>
        <p class="text-primary-400 text-xl max-w-md leading-relaxed">
          Primera reunión sin costo. Cuéntame tu idea y exploramos cómo puedo ayudarte.
        </p>
      </div>

      <div class="space-y-10">
        <div class="flex items-center gap-6 group">
          <div class="text-[#8B7355]">
            <TelephoneIcon/>
          </div>
          <div class="flex flex-col">
            <span class="text-[#8B7355] font-bold text-sm uppercase">Número de Celular</span>
            <span class="text-[#102A26] text-2xl font-bold tracking-wide">+591 71587412</span>
          </div>
        </div>

        <div class="flex items-center gap-6 group">
          <div class="text-[#8B7355]">
            <WhatsappIcon size="size-15" primaryColor='var(--color-accent-700)' />
          </div>
          <div class="flex flex-col">
            <span class="text-accent-700 font-bold text-sm uppercase">WhatsApp</span>
            <span class="text-[#102A26] text-2xl font-bold tracking-wide">+591 71587412</span>
          </div>
        </div>

        <div class="flex items-center gap-6 group">
          <div class="text-[#8B7355]">
            <EmailIcon/>
          </div>
          <div class="flex flex-col">
            <span class="text-accent-700 font-bold text-sm uppercase">Correo Electrónico</span>
            <span class="text-[#102A26] text-2xl font-bold tracking-wide">ejemplo@gmail.com</span>
          </div>
        </div>
      </div>

      <a href="https://wa.me/59171587412" target="_blank" class="w-fit bg-[#102A26] text-[#F4EDE4] px-8 py-4 rounded-xl flex items-center gap-4 hover:bg-[#1a3d38] transition-all shadow-lg group">
        <div class="text-white">
          <WhatsappIcon size="size-6" primaryColor='white' />
        </div>
        <span class="font-bold text-lg">Escribir por WhatsApp</span>
      </a>
    </div>

    <div class="flex justify-center lg:justify-end">
      <ContactForm client:load />
    </div>

  </div>
</section>
