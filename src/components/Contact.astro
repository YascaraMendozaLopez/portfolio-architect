---
import { ContactForm } from './ContactForm';
import { TelephoneIcon } from '../assets/icons/TelephoneIcon';
import { WhatsappIcon } from '../assets/icons/Whatsapp';
import { EmailIcon } from '../assets/icons/EmailIcon';
import CornerLeft from '../../public/images/CornerLeft.svg';
import Button from '../ui/Button';
---

<section id="contact" class="relative min-h-screen w-full bg-secondary overflow-hidden flex items-center justify-center p-6 md:p-12 lg:p-20 lg:pb-30! pb-20!">
  
  <div class="absolute inset-0 pointer-events-none opacity-10 md:opacity-20" 
       style="background-image: linear-gradient(#8B7355 1px, transparent 1px), linear-gradient(90deg, #8B7355 1px, transparent 1px); background-size: calc(100% / 7) calc(100% / 5);">
  </div>

  <img 
    src={CornerLeft.src} 
    class="hidden md:block absolute bottom-10 left-16 w-32 md:w-[370px] opacity-40 md:opacity-100 pointer-events-none" 
    alt="Decoración"
  />

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-8 lg:gap-4 items-end w-full max-w-7xl">
    
    <div class="flex flex-col gap-10 md:gap-16 pl-0 lg:pl-8">
      <div class="space-y-4">
        <span class="text-accent-700 font-bold tracking-[0.2em] text-[clamp(1rem,1.2vw,1.3rem)] uppercase ">Contacto</span>
        <h2 class="font-urbanist text-[clamp(2rem,3.5vw,4.8rem)] text-primary-400 leading-tight mt-4 font-medium">
          Comencemos tu <span class="font-bold italic text-accent-700">proyecto</span>
        </h2>
        <p class="text-primary-400 text-[clamp(1rem,2vw,1.25rem)] max-w-fit lg:max-w-md leading-relaxed opacity-90">
          Primera reunión sin costo. Cuéntame tu idea y exploramos cómo puedo ayudarte.
        </p>
      </div>
      <div class=" w-fit mx-auto flex flex-col gap-10 md:gap-16 border-accent-500 lg:border-none border-2 lg:px-0 lg:py-0 px-8 py-10 rounded-xl bg-secondary lg:bg-transparent shadow-md lg:shadow-none">
        <div class="space-y-8 md:space-y-10">
          <div class="flex items-center gap-5 md:gap-6 group">
            <div class="text-accent-700 shrink-0">
              <TelephoneIcon />
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-accent-700 font-bold text-[clamp(1.1rem,1.2vw,1.5rem)] tracking-wider">Número de Celular</span>
              <span class="text-primary-400 text-[clamp(1.3rem,1.5vw,1.8rem)] font-bold tracking-wide">+591 71587412</span>
            </div>
          </div>
  
          <div class="flex items-center gap-5 md:gap-6 group">
            <div class="text-accent-700 shrink-0">
              <WhatsappIcon size="size-10 md:size-12" primaryColor='var(--color-accent-700)' />
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-accent-700 font-bold text-[clamp(1.1rem,1.2vw,1.5rem)] tracking-wider">WhatsApp</span>
              <span class="text-primary-400 text-[clamp(1.3rem,1.5vw,1.8rem)] font-bold tracking-wide">+591 71587412</span>
            </div>
          </div>
  
          <div class="flex items-center gap-5 md:gap-6 group">
            <div class="text-accent-700 shrink-0">
              <EmailIcon />
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-accent-700 font-bold text-[clamp(1.1rem,1.2vw,1.5rem)] tracking-wider">Correo Electrónico</span>
              <span class="text-primary-400 text-[clamp(1.3rem,1.5vw,1.8rem)] font-bold tracking-wide break-all">mendozajesus.arq@gmail.com</span>
            </div>
          </div>
        </div>
        <Button
          customClass="z-20 flex items-center justify-center gap-4 bg-primary-400 rounded-2xl px-8 py-3 w-fit text-[clamp(1.1rem,1.2vw,1.3rem)] font-medium shadow text-primary-50 w-full hover:bg-primary-900 hover:shadow-[2px_4px_2px_rgb(0,0,0,0.5)] transition-all duration-300 hover:scale-105"
          text="Escribir por WhatsApp"
          Icon={WhatsappIcon}
          iconColor='var(--color-primary-50)'
          whatsappMessage="Hola, tengo un proyecto en mente, necesto su ayuda"
          ariaLabel="Solicitar apoyo por WhatsApp (abre en una nueva ventana)"
        />
      </div>
    </div>

    <div class="flex justify-center lg:justify-end w-full">
      <div class="w-full max-w-lg lg:max-w-md">
        <ContactForm client:load />
      </div>
    </div>

  </div>
</section>
