---
import { LineReviewIcon } from '../assets/icons/LineRewiew';
import ReviewsSlider from './ReviewsSlider';

const reviews = [
  {
    text: "El proceso fue increíblemente ordenado. El resultado superó nuestras expectativas.",
    author: "Carlos & Sofía Ramírez",
    year: "2024"
  },
  {
    text: "Trabajo impecable y comunicación constante en todo momento.",
    author: "María López",
    year: "2024"
  },
  {
    text: "Una experiencia profesional de principio a fin.",
    author: "Juan Pérez",
    year: "2024"
  },
  {
    text: "Volveríamos a trabajar con ellos sin dudarlo.",
    author: "Empresa X",
    year: "2025"
  }
];
---

<section class="flex h-screen bg-linear-to-l from-primary-400 to-primary-900 pl-10 md:pl-32 pr-10 md:pr-24 relative overflow-hidden lg:overflow-visible">

  <div class="relative lg:grid flex flex-col lg:grid-cols-2 gap-16 items-end bg-[url('/images/bg-review.svg')] bg-no-repeat bg-top md:bg-left bg-contain h-[80%] my-14 md:my-auto">

    <div class="flex w-full lg:w-auto flex-col gap-4 pb-0 md:pb-16">
      <p class="text-[clamp(1rem,1.3vw,1.5rem)] text-accent-500 uppercase">
        Clientes
      </p>
      <h1 class="font-urbanist text-[clamp(2rem,3.5vw,4.8rem)] text-primary-50 leading-tight">
        <p class="block">Lo que dicen</p>
        <p class="block">
          quienes <span class="text-accent-500 italic">confiaron</span>
        </p>
      </h1>
    </div>

    <ReviewsSlider reviews={reviews} client:load {...({} as any)} />

  </div>

  <div class="hidden lg:flex w-[35rem] absolute bottom-30 left-14 translate-y-full pointer-events-none z-10">
    <LineReviewIcon/>
  </div>

</section>
