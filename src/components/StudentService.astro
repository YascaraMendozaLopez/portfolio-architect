---
import Button from "../ui/Button";
import {WhatsappIcon} from "../assets/icons/Whatsapp";
import ServiceItem from "./StudentServiceItem";

const services = [
  {
    number: "01",
    title: "Asesoría completa",
    description:
      "Te acompaño en todo el proceso: desde la memoria descriptiva y los planos técnicos hasta la maqueta de entrega"
  },
  {
    number: "02",
    title: "Diseño de planos",
    description:
      "Elaboro los planos técnicos que necesitas. Plantas, cortes, fachadas y detalles"
  },
  {
    number: "03",
    title: "Maquetas de presentación",
    description:
      "Construyo la maqueta física o digital. Escala, materiales y nivel de detalle ajustados a lo que requiere tu entrega final"
  }
];
---

<section class="h-fit lg:h-screen flex flex-col gap-15 lg:gap-8 lg:flex-row bg-linear-to-br from-primary-400 to-primary-900 lg:bg-conic-[from_-90deg_at_55%_45%,#163832_90deg,#051F20_250deg,#031210_360deg] py-16 lg:py-0 px-[clamp(2rem,5vw,8rem)] justify-between items-center shadow-[0px_8px_8px_rgb(0,0,0,0.5)]">
  <div class="lg:relative flex flex-col w-full lg:w-auto">
    <div class="lg:relative -top-10 pl-0 lg:pl-10 flex w-full lg:w-auto flex-col gap-4 ">
      <p class="text-[clamp(1rem,1.3vw,1.5rem)] text-accent-500 uppercase">
        Servicio para estudiantes
      </p>
      <h1 class="font-urbanist text-[clamp(2rem,3.5vw,4.8rem)] text-primary-50 leading-tight">
        <p class="block">
          Apoyo para tu <span class="text-accent-500 italic">tesis/ </span>
        </p>
        <p class="block"><span class="text-accent-500 italic">proyecto</span> de arquitectura</p>
      </h1>
    </div>
    <div class="hidden lg:relative -bottom-20 lg:flex flex-col gap-8">
      <p class="text-[clamp(1rem,1.3vw,1.5rem)] text-accent-500 uppercase">
        Para estudiantes de arquitectura · ingeniería · urbanismo
      </p>
      <div class="flex flex-col gap-4 items-center border-2 border-accent-500 bg-accent-500/10 p-8 w-[93%]">
        <p class="text-primary-100 italic text-[clamp(1.1rem,1.3vw,1.5rem)] text-center">¿La fecha de entrega se acerca y todavía no iniciaste tu tesis/proyecto?</p>
        <Button
          customClass="flex items-center justify-center gap-4 bg-accent-500 rounded-2xl px-8 py-3 w-fit text-[clamp(1.1rem,1.2vw,1.3rem)] font-medium shadow hover:bg-primary-50 hover:blur-5 hover:shadow-[2px_8px_2px_rgb(0,0,0,0.5)] transition-all duration-300 hover:scale-105"
          text="Hablemos hoy"
          Icon={WhatsappIcon}
          whatsappMessage="Hola, necesito apoyo con mi tesis/proyecto de arquitectura"
          ariaLabel="Solicitar apoyo por WhatsApp (abre en una nueva ventana)"
        />
      </div>
    </div>
  </div>
  <div class="flex flex-col gap-10 w-full lg:w-auto">
    {services.map((service, i) => (
      <ServiceItem {...service} client:load {...({} as any)} />
    ))}

  </div>
  <div class="lg:hidden flex flex-col gap-8">
    <p class="text-[clamp(1rem,1.3vw,1.5rem)] text-accent-500 uppercase text-center">
      Para estudiantes de arquitectura · ingeniería · urbanismo
    </p>
    <div class="flex flex-col gap-4 items-center border-2 border-accent-500 bg-accent-500/10 p-8 w-[93s%]">
      <p class="text-primary-100 italic text-[clamp(1.1rem,1.3vw,1.5rem)] text-center">¿La fecha de entrega se acerca y todavía no iniciaste tu tesis/proyecto?</p>
      <Button
        customClass="flex items-center justify-center gap-4 bg-accent-500 rounded-2xl px-8 py-3 w-fit text-[clamp(1.1rem,1.2vw,1.3rem)] font-medium shadow"
        text="Hablemos hoy"
        Icon={WhatsappIcon}
        whatsappMessage="Hola, necesito apoyo con mi tesis/proyecto de arquitectura"
        ariaLabel="Solicitar apoyo por WhatsApp (abre en una nueva ventana)"
      />
    </div>
  </div>
</section>