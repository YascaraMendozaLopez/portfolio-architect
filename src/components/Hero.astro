---
import { HeroLineLeft } from "../assets/icons/LineHeroLeft";
import { HeroLineRight } from "../assets/icons/LineHeroRight";
import Button from "../ui/Button";
---

<section
  class="relative min-h-screen pt-20 px-5
  overflow-hidden
  bg-[radial-gradient(circle_at_center,_var(--color-primary-500)_0%,_var(--color-primary-800)_70%)]
  shadow-[0_4px_4px_rgba(0,0,0,0.25)]"
>
  <div class="absolute inset-0 bg-[url('/images/bg-hero.svg')] bg-cover opacity-80 bg-center z-0" />

  <div class="relative z-10 w-full min-h-[calc(100vh-5rem)]
    grid grid-rows-[0.8fr_0.7fr] lg:grid-rows-1
    lg:grid-cols-2 lg:items-center
  ">

    <div class="flex flex-col items-center lg:items-end text-primary-50
      gap-6 md:gap-8
      justify-center
      pr-2 lg:pr-[25%]
      order-1 lg:order-2"
    >
      <h1
        class="flex flex-wrap gap-2 lg:gap-4 font-urbanist leading-[0.95] tracking-widest
        text-[clamp(2.5rem,4.5vw,5.5rem)] justify-center lg:justify-end
        text-center lg:text-right"
      >
        <span class="block">Espacios que </span>
        <span class="block italic text-accent-500">
          trascienden
        </span>
      </h1>

      <p class="font-nunito text-[clamp(1.2rem,1.7vw,1.9rem)] text-primary-50/90 text-center lg:text-right">
        Diseño residencial y comercial
      </p>

      <Button
        customClass="flex items-center justify-center gap-4 bg-accent-500 rounded-2xl px-8 py-3 w-fit text-[clamp(1rem,1.2vw,1.3rem)] font-bold shadow hover:bg-primary-50 hover:shadow-[2px_8px_2px_rgb(0,0,0,0.5)] transition-all duration-300 hover:scale-105 text-accent-900 uppercase text-center"
        text="Solicitar consulta gratuita"
        whatsappMessage="Hola, tengo un proyecto en mente en el que quisiera que me guíe"
        ariaLabel="Solicitar consulta en whatsapp (abre en una nueva ventana)"
      />

      <p class="absolute bottom-[5%] md:bottom-[10%] right-0 h-[12vw] lg:h-auto w-1/2 lg:w-auto lg:bottom-0 lg:relative italic text-primary-100/90 text-[clamp(1rem,1.5vw,1.8rem)] tracking-wide text-right md:right-10 lg:text-right md:mt-4 lg:mt-20">
        Arq. Jesús Mendoza
      </p>
    </div>

    <div class="order-2 lg:order-1 flex items-end">
      <img
        src="/images/hero-image.svg"
        alt="Arquitectura"
        class="w-full block h-full lg:w-[140%] lg:relative lg:bottom-0 lg:left-15 lg:left-55
        pointer-events-none select-none object-cover object-left"
      />
    </div>

  </div>

  <div class="hidden lg:block absolute right-[7%] bottom-[6%] w-24 pointer-events-none">
    <HeroLineRight />
  </div>
</section>
<div class="hidden lg:block absolute left-[5%] top-[40%] w-24 pointer-events-none z-20">
  <HeroLineLeft />
</div>