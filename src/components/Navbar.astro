---
import { LogoIcon } from "../assets/icons/LogoIcon.tsx";
import Button from "../ui/Button";

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/#projects", label: "Proyectos" },
  { href: "/#about", label: "Sobre mi" },
  { href: "/#services", label: "Servicios" },
  { href: "/#students", label: "Estudiantes" },
  { href: "/#renders", label: "Renders" },
  { href: "/#contact", label: "Contacto" },
];
---

<nav id="navbar" class="fixed top-0 left-0 w-full z-50 flex items-center justify-between py-8 px-8 lg:px-14 transition-all duration-500">
  <a href="/" class="flex items-center z-50">
    <LogoIcon size="size-14 lg:size-18 ml-0 xl:ml-8" />
  </a>

  <button id="menu-toggle" class="lg:hidden z-50 text-accent-500 focus:outline-none" aria-label="Abrir menú">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
    </svg>
  </button>

  <div 
    id="menu-items" 
    class="fixed inset-y-0 right-0 w-full bg-primary-900 flex flex-col items-center justify-center gap-8 translate-x-full invisible opacity-0 pointer-events-none transition-all duration-300 ease-in-out z-40 
           lg:static lg:flex lg:flex-row lg:translate-x-0 lg:visible lg:opacity-100 lg:pointer-events-auto lg:bg-transparent lg:w-auto lg:h-auto lg:gap-8 lg:p-0"
  >
    <div id="nav-links-container" class="text-center flex flex-col lg:flex-row items-center gap-8 font-nunito text-accent-500 font-medium text-[clamp(0.8rem,0.9vw,1.1rem)] uppercase">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          data-nav-link
          class="pb-1 transition-all hover:scale-110"
        >
          {link.label}
        </a>
      ))}
      <Button
        customClass="flex text-center items-center justify-center lg:max-w-[8rem] lg:w-[7rem] xl:max-w-fit xl:w-fit border border-accent-500 rounded-[5px] py-2 px-4 transition-all hover:bg-accent-500 hover:text-primary-900"
        text="Consulta Gratuita"
        whatsappMessage="Hola, tengo un proyecto en mente y me gustaría recibir asesoramiento"
        ariaLabel="Solicitar asesoramiento por WhatsApp (abre en una nueva ventana)"
      />
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const menuItems = document.getElementById('menu-items');
  const menuIcon = document.getElementById('menu-icon');
  const links = document.querySelectorAll('[data-nav-link]');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-primary-900', 'shadow-lg', 'py-2');
      navbar?.classList.remove('py-8');
    } else {
      navbar?.classList.remove('bg-primary-900', 'shadow-lg', 'py-2');
      navbar?.classList.add('py-8');
    }
  });

  const toggleMenu = (forceClose = false) => {
    const isOpening = forceClose ? false : menuItems?.classList.contains('translate-x-full');
    
    if (isOpening) {
      menuItems?.classList.remove('translate-x-full', 'invisible', 'opacity-0', 'pointer-events-none');
      menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    } else {
      menuItems?.classList.add('translate-x-full', 'invisible', 'opacity-0', 'pointer-events-none');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    }
  };

  const updateActiveLink = () => {
    const currentPath = window.location.pathname;
    const currentHash = window.location.hash;

    links.forEach(link => {
      const href = link.getAttribute('href');
      const isActive = (href === currentPath + currentHash) || 
                       (href === "/" && currentPath === "/" && currentHash === "") ||
                       (href === currentHash);

      if (isActive) {
        link.classList.add('border-b-2', 'border-dotted', 'border-accent-500', 'italic');
      } else {
        link.classList.remove('border-b-2', 'border-dotted', 'border-accent-500', 'italic');
      }
    });
  };

  menuToggle?.addEventListener('click', () => toggleMenu());
  links.forEach(link => link.addEventListener('click', () => toggleMenu(true)));
  window.addEventListener('hashchange', updateActiveLink);
  window.addEventListener('load', updateActiveLink);
  updateActiveLink();
</script>