---
import { LogoIcon } from "../assets/icons/LogoIcon.tsx";
const { pathname } = Astro.url;

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/#projects", label: "Proyectos" },
  { href: "/#about", label: "Sobre mi" },
  { href: "/#services", label: "Servicios" },
  { href: "/#students", label: "Estudiantes" },
  { href: "/#renders", label: "Renders" },
  { href: "/#contact", label: "Contacto" },
];
---

<nav class="absolute top-0 left-0 w-full z-50 flex items-center justify-between py-4 px-8 bg-linear-to-l from-primary-400 to-primary-900 lg:px-24">
  <a href="/" class="flex items-center gap-4 z-50">
    <LogoIcon size="size-16 lg:size-20" />
  </a>

  <button id="menu-toggle" class="lg:hidden z-50 text-accent-500 focus:outline-none" aria-label="Abrir menú">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
    </svg>
  </button>

  <div 
    id="menu-items" 
    class="fixed inset-0 bg-primary-900 flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 ease-in-out z-40 
           lg:static lg:flex-row lg:translate-x-0 lg:bg-transparent lg:w-auto lg:h-auto lg:gap-8 lg:p-0"
  >
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-10 font-nunito text-accent-500 font-medium text-[14px] lg:text-[12px] uppercase">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class={`pb-1 transition-all hover:scale-110 ${pathname === link.href ? "border-b-2 border-dotted border-accent-500 italic" : ""}`}
        >
          {link.label}
        </a>
      ))}
      
      <a 
        href="#contact"
        class="flex items-center justify-center w-[180px] lg:w-[161px] h-[45px] lg:h-[38px] border border-accent-500 rounded-[5px] py-2 px-4 transition-all hover:bg-accent-500 hover:text-primary-900"
      >
        Consulta Gratuita
      </a>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuItems = document.getElementById('menu-items');
  const menuIcon = document.getElementById('menu-icon');

  menuToggle?.addEventListener('click', () => {
    // Alternar clase para mostrar/ocultar menú en móvil
    menuItems?.classList.toggle('translate-x-full');
    
    // Opcional: Cambiar el icono de hamburguesa a una "X"
    const isOpen = !menuItems?.classList.contains('translate-x-full');
    if (isOpen) {
        menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    } else {
        menuIcon?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    }
  });

  // Cerrar el menú al hacer click en un link (importante para SPAs o anchors)
  const links = menuItems?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      menuItems?.classList.add('translate-x-full');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    });
  });
</script>
