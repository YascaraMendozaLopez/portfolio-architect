---
import ProjectSlider from "./ProjectSlider";
import { LineProjectLeft } from "../assets/icons/LineProjectLeft";
import { LineProjectRight } from "../assets/icons/LineProjectRight";
import { DoorIcon } from "../assets/icons/DoorIcon";
---

<section
  class="bg-secondary min-h-screen md:h-screen py-10 px-6 md:px-20 relative overflow-hidden"
>
  <div class="hidden md:block absolute inset-0 pointer-events-none z-0">
    <div class="absolute left-[-44px] top-[36%] h-full">
      <LineProjectLeft />
    </div>

    <div class="absolute right-18 bottom-10">
      <LineProjectRight />
    </div>

    <div class="absolute left-[86px] top-[212px] -translate-y-1/2">
      <DoorIcon />
    </div>

    <img src="/images/project-image.svg" class="absolute right-20 top-12" />
  </div>

  <div class="relative z-20 w-full md:w-[88%] md:left-[8%]">
    <div class="text-center md:text-left mt-4">
      <p
        class="font-nunito font-bold text-accent-700 uppercase text-[12px] md:text-[14px] tracking-wide"
      >
        Portafolio
      </p>

      <h2
        class="font-urbanist text-2xl md:text-5xl text-primary-500 mt-2 md:ml-2"
      >
        Proyectos <span
          class="italic font-bold text-accent-700 [text-shadow:2px_2px_2px_rgba(43,34,19,0.25)]"
          >destacados</span
        >
      </h2>
    </div>

    <div class="relative flex items-center justify-center mt-8 md:mt-2">
      <ProjectSlider client:load />
    </div>
  </div>

  <img
    src="/images/project-image-center.svg"
    class="hidden md:block absolute bottom-[-1%] left-[52%] -translate-x-1/2 z-0 w-[500px] md:w-[600px] pointer-events-none"
    alt=""
  />
</section>
