---
import ProjectSlider from "./ProjectSlider";
import { LineProjectLeft } from "../assets/icons/LineProjectLeft";
import { LineProjectRight } from "../assets/icons/LineProjectRight";
import { DoorIcon } from "../assets/icons/DoorIcon";
---

<section
  id="projects"
  class="bg-primary
  py-16
  md:py-20
  lg:pt-[3%] lg:pb-0
  relative
  overflow-visible
  lg:overflow-hidden
  min-h-[600px] md:min-h-[700px] lg:min-h-auto"
>
  <div class="absolute inset-0 pointer-events-none z-0 hidden lg:block">
    <div class="absolute left-[10%] top-[60%] -translate-y-1/2">
      <LineProjectLeft />
    </div>

    <div class="absolute right-[5%] bottom-[11%]">
      <LineProjectRight />
    </div>

    <div class="absolute left-[5.5%] top-[22%]">
      <DoorIcon />
    </div>

    <img
      src="/images/project-image.svg"
      class="absolute right-[5%] top-[5%] max-w-[220px] opacity-70"
    />
  </div>

  <div class="relative z-20 max-w-6xl mx-auto px-6 md:px-8 lg:ml-[11%]">
    <div class="text-center md:text-center lg:text-left">
      <p
        class="font-nunito font-bold text-accent-700 uppercase text-xs md:text-sm tracking-wide"
      >
        Portafolio
      </p>

      <h2
        class="font-urbanist text-2xl md:text-4xl lg:text-5xl text-primary-500 mt-2"
      >
        Proyectos
        <span class="italic font-bold text-accent-700 [text-shadow:2px_2px_2px_rgba(43,34,19,0.25)]">
          destacados
        </span>
      </h2>
    </div>

    <div class="mt-8 md:mt-10 flex justify-center pb-10 md:pb-16 lg:pb-0">
      <ProjectSlider client:load />
    </div>
  </div>

  <div class="hidden lg:flex justify-center mt-10 pointer-events-none">
    <img
      src="/images/project-image-center.svg"
      class="max-w-[500px] lg:max-w-[650px] w-full lg:ml-[7%]"
      alt=""
    />
  </div>
</section>
