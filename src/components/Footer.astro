      <img src="/images/logo.svg" alt="Logo" class="w-full md:w-full" />

      <!-- NAME -->
      <div class="font-urbanist text-accent-500">
        <p class="text-lg md:text-xl font-semibold leading-tight">ARQ. JESÚS</p>
        <p class="text-lg md:text-xl font-semibold leading-tight">MENDOZA</p>
